{
  "name": "narukealpha-convex-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && npm run build:electron && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "dev:convex": "convex dev --local",
    "build": "npm run build:renderer && npm run build:electron",
    "build:web": "npm run build:renderer",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173",
    "build:renderer": "vite build",
    "build:electron": "npm run build:electron:main && npm run build:electron:preload",
    "build:electron:main": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=dist/electron/main.js --external:electron",
    "build:electron:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist/electron/preload.cjs --external:electron",
    "check": "tsc --noEmit && npm run build:renderer && npm run build:electron && tsx scripts/check.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.21",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.8",
    "react-grab": "^0.1.28",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
