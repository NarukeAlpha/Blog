{
  "name": "narukealpha-convex-studio",
  "version": "0.1.0",
  "description": "Standalone Electron writing studio for NarukeAlpha.",
  "author": "NarukeAlpha",
  "private": true,
  "type": "module",
  "main": "dist/studio/electron/main.js",
  "scripts": {
    "start": "npm run build:studio && electron .",
    "dev": "npm run dev:studio",
    "dev:all": "concurrently -k \"npm:dev:site\" \"npm:dev:studio\"",
    "dev:site": "vite --config apps/site/vite.config.ts",
    "dev:studio": "concurrently -k \"npm:dev:studio:renderer\" \"npm:dev:studio:electron\"",
    "dev:studio:renderer": "vite --config apps/studio/vite.config.ts",
    "dev:studio:electron": "wait-on tcp:127.0.0.1:5174 && npm run build:studio:electron && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron .",
    "dev:convex": "convex dev --local",
    "build": "npm run build:site && npm run build:studio",
    "build:web": "npm run build:site",
    "build:site": "vite build --config apps/site/vite.config.ts",
    "preview:web": "npm run preview:site",
    "preview:site": "vite preview --config apps/site/vite.config.ts",
    "build:studio": "npm run build:studio:renderer && npm run build:studio:electron",
    "build:studio:renderer": "vite build --config apps/studio/vite.config.ts",
    "build:studio:electron": "npm run build:studio:electron:main && npm run build:studio:electron:preload",
    "build:studio:electron:main": "esbuild apps/studio/electron/main.ts --bundle --platform=node --format=esm --outfile=dist/studio/electron/main.js --external:electron",
    "build:studio:electron:preload": "esbuild apps/studio/electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist/studio/electron/preload.cjs --external:electron",
    "package:studio": "npm run build:studio && electron-builder --mac dmg --win nsis",
    "package:studio:dir": "npm run build:studio && electron-builder --dir",
    "check": "tsc --noEmit && npm run build:site && npm run build:studio && tsx scripts/check.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.21",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "lucide-react": "^0.544.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "react-grab": "^0.1.28",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "8.0.7",
    "vitest": "4.1.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.narukealpha.studio",
    "productName": "NarukeAlpha Post Studio",
    "asar": true,
    "directories": {
      "output": "release/studio"
    },
    "files": [
      "dist/studio/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
