# Local website development
# Local app runs use the hosted dev Convex deployment by default.
VITE_CONVEX_URL=https://your-dev-deployment.convex.cloud
VITE_PUBLIC_SITE_URL=http://127.0.0.1:5173

# Electron studio targets
STUDIO_DEV_CONVEX_URL=https://your-dev-deployment.convex.cloud
STUDIO_DEV_CONVEX_SITE_URL=https://your-dev-deployment.convex.site
STUDIO_DEV_PUBLIC_SITE_URL=https://your-dev-site.example.com
STUDIO_DEV_WRITE_KEY=replace-this-with-your-dev-studio-write-key

STUDIO_PROD_CONVEX_URL=https://ardent-firefly-400.convex.cloud
STUDIO_PROD_CONVEX_SITE_URL=https://ardent-firefly-400.convex.site
STUDIO_PROD_PUBLIC_SITE_URL=https://blog.alphadevahjin.com
STUDIO_PROD_WRITE_KEY=replace-this-with-your-prod-studio-write-key

# Optional first-run studio target override
STUDIO_ENVIRONMENT=dev

# Optional Convex CLI config if you want to run `npx convex dev --local`
CONVEX_DEPLOYMENT=dev:your-dev-deployment
CONVEX_DEPLOY_KEY_DEV=dev:your-dev-deployment|replace-this-with-your-dev-deploy-key

# Optional bookmark enrichment
OPENCODE_COMMAND=opencode
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_PROVIDER_ID=openai
OPENCODE_MODEL_ID=gpt-5.4
